# Crosscheck LLM configuration — copy to `.env` and pick ONE profile below.
#
# Crosscheck runs entirely on whatever LLM cognee is pointed at. Provider is
# chosen purely by env vars — no code changes. Pick a profile, uncomment it,
# leave the others commented.
#
# COGNEE_SKIP_CONNECTION_TEST=true skips cognee's startup probe of the LLM
# endpoint so ingest starts immediately; keep it for all profiles.
COGNEE_SKIP_CONNECTION_TEST=true
# Access control (multi-user graph scoping) is ON by default and splits the
# graph into per-user/per-dataset stores, so a direct graph read comes back
# empty. Crosscheck reads the whole graph, so keep it OFF for all profiles.
ENABLE_BACKEND_ACCESS_CONTROL=false

# ─────────────────────────────────────────────────────────────────────────────
# PROFILE A — Local Llama via Ollama  (default; this is the profile we test)
# ─────────────────────────────────────────────────────────────────────────────
# Free, offline, no API key. Needs: `ollama serve` running, and the two models
# pulled:  `ollama pull llama3.1:8b`  and  `ollama pull nomic-embed-text`.
#
# NOTE: small local models don't reliably emit schema-valid JSON, so cognee's
# default `instructor` structured-output path fails mid-cognify. We switch it to
# the BAML framework (schema-aligned parsing tolerates loose JSON). This is why
# the BAML_* block below exists — it is REQUIRED for the local-Llama profile.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama
STRUCTURED_OUTPUT_FRAMEWORK=baml
BAML_LLM_PROVIDER=openai-generic
BAML_LLM_MODEL=llama3.1:8b
BAML_LLM_ENDPOINT=http://localhost:11434/v1
BAML_LLM_API_KEY=ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5

# ─────────────────────────────────────────────────────────────────────────────
# PROFILE B — OpenAI  (opt-in; NOT tested by us — costs money, needs a key)
# ─────────────────────────────────────────────────────────────────────────────
# For anyone who can't/won't run local models. Strong models honor the schema,
# so the default `instructor` framework works — do NOT set STRUCTURED_OUTPUT_
# FRAMEWORK or the BAML_* vars. Comment out Profile A entirely first.
#
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...your-openai-key...
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ─────────────────────────────────────────────────────────────────────────────
# PROFILE C — Google Gemini  (opt-in; NOT tested by us — needs a key)
# ─────────────────────────────────────────────────────────────────────────────
# Same idea as OpenAI: strong model, keep the default `instructor` framework.
# Comment out Profile A first.
#
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=...your-gemini-key...
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini/text-embedding-004
# EMBEDDING_DIMENSIONS=768
